    "# Asset Class Trend Following 策略回測 (equityV1)\n",
    "\n",
    "本報告針對 **2019-01-01 - 2026-03-31** 期間進行回測。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ae8d2602",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from backtest_v2 import clean_data, BacktesterV2, calculate_metrics\n",
    "\n",
    "# 1. 資料讀取與清洗\n",
    "# 註：此處假設 '資料-1.xlsx' 已存在，若需重新清洗可執行 generate_equityV1.py\n",
    "prices, volumes, code_to_name = clean_data('資料-1.xlsx')\n",
    "\n",
    "# 2. 設定參數與執行回測\n",
    "sma, roc, sl, reb = 303, 14, 0.0999, 9\n",
    "bt = BacktesterV2(prices, volumes, code_to_name)\n",
    "eq, trades, hold, trades2, daily = bt.run(sma, roc, sl, reb, 'peak', 10)\n",
    "\n",
    "# 3. 篩選指定期間績效\n",
    "mask = (eq['日期'] >= '2019-01-01') & (eq['日期'] <= '2026-03-31')\n",
    "res_p = eq[mask]\n",
    "\n",
    "# 4. 繪製權益曲線\n",
    "plt.figure(figsize=(12, 6))\n",
    "plt.plot(res_p['日期'], res_p['權益'])\n",
    "plt.title(f'Equity Curve (equityV1)')\n",
    "plt.grid(True)\n",
    "plt.show()\n",
    "\n",
    "# 5. 計算績效指標\n",
    "cagr, mdd, calmar, total_ret = calculate_metrics(res_p)\n",
    "print(f\"年化報酬率 (CAGR): {cagr:.2%}\")\n",
    "print(f\"最大回撤 (MaxDD): {mdd:.2%}\")\n",
    "print(f\"Calmar Ratio: {calmar:.2f}\")\n",
    "\n",
# Walk-Forward Analysis 樣板程式 (含自動繪製權益曲線)

import matplotlib.pyplot as plt

# 定義多個回測區間
periods = [
    ('2019-01-02', '2021-12-31'), 
    ('2019-06-01', '2022-05-31'),
    ('2020-01-02', '2022-12-31'),
    ('2020-06-01', '2023-05-31'),
    ('2021-01-02', '2023-12-31'),
    ('2021-06-01', '2024-05-31'),
    ('2022-01-02', '2024-12-31'),
    ('2022-06-01', '2025-05-31'),
    ('2023-01-02', '2025-12-31'),
]

# 儲存結果
wfa_results = []

plt.figure(figsize=(12, 6))

for start, end in periods:
    mask = (eq['日期'] >= start) & (eq['日期'] <= end)
    res = eq[mask]
    cagr, mdd, calmar, total_ret = calculate_metrics(res)
    wfa_results.append({
        '區間': f"{start} ~ {end}",
        'CAGR': f"{cagr:.2%}",
        'MaxDD': f"{mdd:.2%}",
        'Calmar': f"{calmar:.2f}",
        '總報酬率': f"{total_ret:.2%}"
    })
    
    # 繪製各區間權益曲線
    plt.plot(res['日期'], res['權益'], label=f"{start} ~ {end}")

plt.title("Walk-Forward Analysis - Equity Curves")
plt.xlabel("日期")
plt.ylabel("權益")
plt.legend()
plt.grid(True)
plt.show()

# 輸出成績表
wfa_df = pd.DataFrame(wfa_results)
print(wfa_df)

    "# 6. 2026 績效\n",
    "mask_2026 = (eq['日期'] >= '2026-01-01') & (eq['日期'] <= '2026-03-31')\n",
    "res_2026 = eq[mask_2026]\n",
    "cagr_2026, mdd_2026, calmar_2026, total_ret_2026 = calculate_metrics(res_2026)\n",
    "print(\"\\n2026 績效 (2026.01.01 - 2026.03.31):\")\n",
    "print(f\"CAGR: {cagr_2026:.2%}\")\n",
    "print(f\"MaxDD: {mdd_2026:.2%}\")\n",
    "print(f\"Calmar Ratio: {calmar_2026:.2f}\")\n"
   ]
